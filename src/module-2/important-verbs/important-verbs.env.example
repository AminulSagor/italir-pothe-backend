# IMPORTANT VERBS - LOCAL LIBRETRANSLATE
# Run LibreTranslate locally before executing `npm run verbs:sync`.
LIBRETRANSLATE_ENABLED=true
LIBRETRANSLATE_ENDPOINT=http://127.0.0.1:5000
LIBRETRANSLATE_API_KEY=
LIBRETRANSLATE_SOURCE_LANGUAGE=en
LIBRETRANSLATE_TARGET_LANGUAGE=bn
LIBRETRANSLATE_BATCH_SIZE=20
LIBRETRANSLATE_BATCH_MAX_CHARACTERS=8000
LIBRETRANSLATE_REQUEST_DELAY_MS=100
LIBRETRANSLATE_MAX_RETRIES=4
LIBRETRANSLATE_TIMEOUT_MS=120000
# Increase this only when you intentionally want all stored Bangla content
# regenerated with a new translation pipeline/model.
LIBRETRANSLATE_PIPELINE_VERSION=v1

# Dataset sources.
IMPORTANT_VERBS_KAIKKI_SOURCE=https://kaikki.org/dictionary/Italian/kaikki.org-dictionary-Italian.jsonl
IMPORTANT_VERBS_UNIMORPH_SOURCE=https://raw.githubusercontent.com/unimorph/ita/master/ita
IMPORTANT_VERBS_TATOEBA_ENDPOINT=https://api.tatoeba.org/v1/sentences

# Import scope.
# Default: use bundled starter list.
IMPORTANT_VERBS_IMPORT_ALL=false
IMPORTANT_VERBS_MAX_VERBS=500
IMPORTANT_VERBS_LEMMA_FILE=
IMPORTANT_VERBS_LEMMAS=

# Tatoeba limits.
IMPORTANT_VERBS_TATOEBA_ENABLED=true
IMPORTANT_VERBS_TATOEBA_MAX_REQUESTS=500
IMPORTANT_VERBS_TATOEBA_REQUEST_DELAY_MS=300

# Update tracking.
IMPORTANT_VERBS_SOURCE_VERSION=kaikki-unimorph-tatoeba-v1
IMPORTANT_VERBS_SYNC_ON_STARTUP=false
IMPORTANT_VERBS_MONTHLY_SYNC_ENABLED=false

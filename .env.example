HOST=0.0.0.0
PORT=5000
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=yourpassword
DB_NAME=italirpothe
TYPEORM_SYNC=true

JWT_SECRET=your_super_secret_jwt_key
JWT_EXPIRES_IN=7d

# SMS & Email Services
SMS_BYPASS=true # Set to false in production
EMAIL_BYPASS=true # Set to false in production

# AWS SES Configuration
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_S3_REGION=ap-south-1
AWS_S3_BUCKET=your_bucket_name

AWS_SES_REGION=ap-south-1
SES_FROM_EMAIL=code4ever.masum99@gmail.com
# Agora Live Streaming
AGORA_APP_ID=your_agora_app_id
AGORA_APP_CERTIFICATE=your_agora_app_certificate
AGORA_TOKEN_EXPIRE_SECONDS=3600



#IMPORTANT_VERBS CONFIGURATETION
# Required only for Bangla translation.
AZURE_TRANSLATOR_KEY=
AZURE_TRANSLATOR_REGION=
AZURE_TRANSLATOR_ENDPOINT=https://api.cognitive.microsofttranslator.com

# Dataset sources.
IMPORTANT_VERBS_KAIKKI_SOURCE=https://kaikki.org/dictionary/Italian/kaikki.org-dictionary-Italian.jsonl
IMPORTANT_VERBS_UNIMORPH_SOURCE=https://raw.githubusercontent.com/unimorph/ita/master/ita
IMPORTANT_VERBS_TATOEBA_ENDPOINT=https://api.tatoeba.org/unstable/sentences

# Import scope.
# Default: use bundled starter list.
IMPORTANT_VERBS_IMPORT_ALL=false
IMPORTANT_VERBS_MAX_VERBS=500
IMPORTANT_VERBS_LEMMA_FILE=
IMPORTANT_VERBS_LEMMAS=

# Tatoeba limits.
IMPORTANT_VERBS_TATOEBA_ENABLED=true
IMPORTANT_VERBS_TATOEBA_MAX_REQUESTS=500
IMPORTANT_VERBS_TATOEBA_REQUEST_DELAY_MS=150

# Update tracking.
IMPORTANT_VERBS_SOURCE_VERSION=
IMPORTANT_VERBS_SYNC_ON_STARTUP=false
IMPORTANT_VERBS_MONTHLY_SYNC_ENABLED=false

# AI Tutor / separately running Pipecat FastAPI service
# Pipecat runs on the same Windows machine during local development.
PIPECAT_SERVICE_URL=http://127.0.0.1:8080
# Must exactly match PIPECAT_INTERNAL_API_KEY in pipecat-backend/.env.
PIPECAT_INTERNAL_API_KEY=replace-with-the-same-long-random-secret
# Voice startup includes worker/model initialization.
PIPECAT_REQUEST_TIMEOUT_MS=60000

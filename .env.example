# =============================================================================
# Italir Pothe NestJS backend - LOCAL DEVELOPMENT
# Copy to .env and replace placeholder values. Never commit the real .env.
# =============================================================================

NODE_ENV=development
HOST=0.0.0.0
PORT=5000

# Admin web origins allowed by CORS. Add your LAN URL when required.
CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:3000

PUBLIC_API_BASE_URL=https://your-api-domain.com

CERTIFICATE_PUBLIC_VERIFY_BASE_URL=https://your-api-domain.com/certificates/public/verify

# PostgreSQL
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=replace-with-your-postgres-password
DB_NAME=italir_pothe
# Local development only. Keep false in production and use migrations.
TYPEORM_SYNC=true

# Authentication
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace-with-a-long-random-jwt-secret
JWT_EXPIRES_IN=7d

# Local OTP testing
EMAIL_BYPASS=true
SMS_BYPASS=true

# AWS S3 / SES
# AWS_S3_BUCKET is required by the current FilesModule during startup.
AWS_ACCESS_KEY_ID=replace-with-your-aws-access-key
AWS_SECRET_ACCESS_KEY=replace-with-your-aws-secret-key
AWS_REGION=ap-south-1
AWS_S3_REGION=ap-south-1
AWS_S3_BUCKET=replace-with-your-s3-bucket-name
# Optional CDN or public bucket URL, without a trailing slash.
AWS_S3_PUBLIC_BASE_URL=
AWS_SES_REGION=eu-central-1
SES_FROM_EMAIL=replace-with-your-verified-ses-sender@example.com

# Firebase push notifications. Leave all three blank to disable Firebase locally.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# Keep escaped newlines exactly as \n when stored in one .env line.
FIREBASE_PRIVATE_KEY=

# Pipecat AI Tutor
PIPECAT_SERVICE_URL=http://127.0.0.1:8080
# Must exactly match pipecat-backend/.env.
PIPECAT_INTERNAL_API_KEY=replace-with-the-same-long-random-secret
PIPECAT_REQUEST_TIMEOUT_MS=60000

# Agora webinar/call token generation
AGORA_APP_ID=
AGORA_APP_CERTIFICATE=
AGORA_TOKEN_EXPIRE_SECONDS=3600

# Payments/demo configuration
PAYMENTS_DEMO_MODE=true
DEMO_EUR_TO_BDT_RATE=130
GOOGLE_PLAY_DEMO_PRODUCT_PREFIX=italir_pothe

# Important-verbs synchronization. Disabled for a normal local startup.
IMPORTANT_VERBS_SYNC_ON_STARTUP=false
IMPORTANT_VERBS_MONTHLY_SYNC_ENABLED=false
IMPORTANT_VERBS_IMPORT_ALL=false
IMPORTANT_VERBS_MAX_VERBS=100
IMPORTANT_VERBS_SOURCE_VERSION=v1
IMPORTANT_VERBS_KAIKKI_SOURCE=
IMPORTANT_VERBS_UNIMORPH_SOURCE=
IMPORTANT_VERBS_LEMMA_FILE=
IMPORTANT_VERBS_LEMMAS=
IMPORTANT_VERBS_TATOEBA_ENABLED=false
IMPORTANT_VERBS_TATOEBA_ENDPOINT=https://tatoeba.org/en/api_v0/search
IMPORTANT_VERBS_TATOEBA_MAX_REQUESTS=500
IMPORTANT_VERBS_TATOEBA_REQUEST_DELAY_MS=150
IMPORTANT_VERBS_TATOEBA_TIMEOUT_MS=15000

# Optional LibreTranslate service used by important-verbs imports.
LIBRETRANSLATE_ENABLED=false
LIBRETRANSLATE_ENDPOINT=http://127.0.0.1:5001
LIBRETRANSLATE_API_KEY=
LIBRETRANSLATE_SOURCE_LANGUAGE=en
LIBRETRANSLATE_TARGET_LANGUAGE=bn
LIBRETRANSLATE_PIPELINE_VERSION=v1
LIBRETRANSLATE_BATCH_SIZE=20
LIBRETRANSLATE_BATCH_MAX_CHARACTERS=8000
LIBRETRANSLATE_REQUEST_DELAY_MS=100
LIBRETRANSLATE_TIMEOUT_MS=30000
LIBRETRANSLATE_MAX_RETRIES=3

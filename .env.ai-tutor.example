# Main NestJS backend -> local Pipecat FastAPI service.
PIPECAT_SERVICE_URL=http://127.0.0.1:8080

# Must exactly match PIPECAT_INTERNAL_API_KEY in pipecat-backend/.env.
# Generate once from the Pipecat directory:
# uv run python -c "import secrets; print(secrets.token_urlsafe(48))"
PIPECAT_INTERNAL_API_KEY=replace-with-the-same-long-random-secret

# Voice startup includes worker/model initialization.
PIPECAT_REQUEST_TIMEOUT_MS=60000

# Railway later:
# PIPECAT_SERVICE_URL=https://your-pipecat-service.up.railway.app
